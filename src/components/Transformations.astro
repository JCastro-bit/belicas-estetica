---
// Transformations.astro
const transformations = [
  { 
    id: 1, 
    type: "Coloración Balayage",
    before: "https://images.unsplash.com/photo-1519699047748-de8e457a634e?q=80&w=800&auto=format&fit=crop", 
    after: "https://images.unsplash.com/photo-1522337660859-02fbefca4702?q=80&w=800&auto=format&fit=crop" 
  },
  { 
    id: 2, 
    type: "Corte Bob Estructurado",
    before: "https://images.unsplash.com/photo-1595476108010-b4d1f10d5e43?q=80&w=800&auto=format&fit=crop", 
    after: "https://images.unsplash.com/photo-1620330101055-1f63a01662fb?q=80&w=800&auto=format&fit=crop" 
  },
  { 
    id: 3, 
    type: "Alisado Espejo",
    before: "https://images.unsplash.com/photo-1580618671404-187515e019f8?q=80&w=800&auto=format&fit=crop", 
    after: "https://images.unsplash.com/photo-1560066984-138dadb4c035?q=80&w=800&auto=format&fit=crop" 
  }
];
---
<section class="bg-brand-darker py-24 md:py-32 relative border-y border-white/5 overflow-hidden">
  <!-- Subtle background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] h-[80vw] max-w-[800px] max-h-[800px] bg-brand-fuchsia/5 rounded-full blur-[150px] -z-10 pointer-events-none"></div>

  <div class="container mx-auto px-4 lg:px-8">
    <div class="text-center mb-16 md:mb-24">
      <h2 class="font-display text-5xl md:text-7xl lg:text-[90px] leading-[0.8] tracking-tighter uppercase text-white mb-6">
        EL RESULTADO  <br />
        <span class="text-brand-fuchsia">HABLA POR SÍ SOLO</span>
      </h2>
      <p class="font-body text-gray-400 text-lg max-w-2xl mx-auto font-light tracking-wide uppercase">
        Desliza para ver la magia. No prometemos, demostramos.
      </p>
    </div>

    <!-- Transformations List -->
    <div class="flex flex-col gap-16 md:gap-32">
      {transformations.map((item, index) => (
        <div class={`flex flex-col ${index % 2 !== 0 ? 'lg:flex-row-reverse' : 'lg:flex-row'} items-center gap-8 lg:gap-16`}>
          
          <!-- Text Info -->
          <div class="w-full lg:w-1/3 flex flex-col justify-center text-center lg:text-left">
            <span class="text-brand-fuchsia font-display text-xl mb-2 tracking-widest text-outline-fuchsia">
              CASO 0{item.id}
            </span>
            <h3 class="font-display text-4xl md:text-5xl uppercase text-white mb-6 leading-none">
              {item.type}
            </h3>
            <div class={`w-12 h-1 bg-brand-fuchsia mx-auto ${index % 2 !== 0 ? 'lg:mx-auto xl:mr-0' : 'lg:mx-0'} lg:mx-0 mb-6 drop-shadow-[0_0_10px_rgba(217,70,239,0.8)]`}></div>
          </div>

          <!-- Images Comparison -->
          <div class="w-full lg:w-2/3 grid grid-cols-2 gap-2 md:gap-4 relative group">
            
            <!-- Badge Before/After Desktop -->
            <div class="absolute top-4 left-4 z-20 bg-black/80 backdrop-blur-sm text-white px-4 py-1 font-display tracking-widest text-sm border border-white/10 uppercase">Antes</div>
            <div class="absolute top-4 right-4 z-20 bg-brand-fuchsia text-white px-4 py-1 font-display tracking-widest text-sm uppercase shadow-[0_0_15px_rgba(217,70,239,0.6)]">Después</div>

            <div class="relative aspect-[3/4] md:aspect-[4/5] overflow-hidden grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700">
              <img src={item.before} alt={`Antes de ${item.type}`} class="object-cover w-full h-full hover:scale-105 transition-transform duration-1000" loading="lazy">
            </div>
            
            <div class="relative aspect-[3/4] md:aspect-[4/5] overflow-hidden group-hover:box-glow-fuchsia transition-shadow duration-500">
              <img src={item.after} alt={`Después de ${item.type}`} class="object-cover w-full h-full hover:scale-105 transition-transform duration-1000" loading="lazy">
              <!-- Overlay to enhance the glow -->
              <div class="absolute inset-0 border-[3px] border-brand-fuchsia/0 group-hover:border-brand-fuchsia/50 transition-colors duration-500 pointer-events-none"></div>
            </div>

            <!-- Central VS element -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-14 h-14 md:w-20 md:h-20 bg-brand-dark border-2 border-brand-fuchsia rounded-full flex items-center justify-center z-20 text-brand-fuchsia font-display text-2xl md:text-4xl shadow-[0_0_30px_rgba(217,70,239,0.8)]">
              VS
            </div>

          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-24 md:mt-32 text-center">
      <a href="https://wa.me/523333986710?text=Hola,%20quiero%20cotizar%20un%20cambio%20de%20look" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center justify-center px-10 py-5 bg-transparent border-2 border-white text-white font-display text-xl md:text-3xl uppercase tracking-widest overflow-hidden transition-all duration-300">
        <span class="absolute inset-0 w-0 bg-white transition-all duration-[250ms] ease-out group-hover:w-full"></span>
        <span class="relative group-hover:text-brand-dark transition-colors duration-300">Quiero mi transformación</span>
      </a>
    </div>

  </div>
</section>
