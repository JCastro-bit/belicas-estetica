---
// Services.astro
const services = [
  { title: "Corte y Estilizado", desc: "Diseño de imagen hiper-personalizado que resalta tus facciones con precisión milimétrica." },
  { title: "Coloración Profesional", desc: "Balayage, babylights, y colores vibrantes con productos premium que protegen la hebra." },
  { title: "Alisados y Keratinas", desc: "Fórmulas exclusivas para un liso perfecto, tipo espejo y sin frizz por meses." },
  { title: "Tratamientos Capilares", desc: "Resurrección capilar profunda para cabellos procesados o sin vida." },
  { title: "Maquillaje Profesional", desc: "Desde el glow natural hasta el glam más agresivo para que seas el centro de atención." },
  { title: "Manicure & Pedicure", desc: "Diseños impecables, duraderos y con detalles que marcan la absoluta diferencia." }
];
---
<section id="servicios" class="bg-brand-dark py-24 md:py-32 relative z-10">
  <div class="container mx-auto px-4 lg:px-8">
    
    <div class="mb-16 md:mb-24 text-center md:text-left flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-3xl">
        <h2 class="font-display text-6xl md:text-8xl lg:text-[110px] leading-[0.8] tracking-tighter uppercase text-white mb-6">
          NUESTROS <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-fuchsia to-magenta-600">SERVICIOS</span>
        </h2>
        <p class="font-body text-gray-400 text-lg md:text-xl max-w-xl font-light">
          No hacemos milagros, hacemos arte. Elevamos tu estilo con técnicas de vanguardia y productos premium.
        </p>
      </div>
      
      <div class="hidden md:flex justify-end pb-4">
        <div class="w-16 h-16 rounded-full border border-brand-fuchsia/40 flex items-center justify-center animate-bounce" style="animation-duration: 3s;">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-fuchsia" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {services.map((service, index) => (
        <div class="group relative bg-[#0a0a0a] border border-white/10 hover:border-brand-fuchsia/60 p-8 md:p-10 transition-all duration-500 overflow-hidden shadow-2xl">
          
          <!-- Hover Effect Background -->
          <div class="absolute inset-0 bg-gradient-to-br from-brand-fuchsia/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10 flex flex-col h-full justify-between">
            <div>
              <div class="text-white/10 font-display text-6xl md:text-7xl mb-6 group-hover:text-brand-fuchsia/20 transition-colors duration-500">
                0{index + 1}
              </div>
              <h3 class="font-display text-3xl md:text-4xl uppercase text-white mb-4 group-hover:text-brand-fuchsia transition-colors duration-300 tracking-wide">
                {service.title}
              </h3>
              <p class="font-body text-gray-400 font-light text-base md:text-lg leading-relaxed group-hover:text-gray-200 transition-colors duration-300">
                {service.desc}
              </p>
            </div>
            
            <div class="mt-8 flex items-center text-brand-fuchsia uppercase font-display tracking-widest text-sm md:text-base opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
              Agenda Ahora 
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>

          <!-- Decorative Hover Lines -->
          <div class="absolute top-0 right-0 w-16 h-16 border-t-[3px] border-r-[3px] border-transparent group-hover:border-brand-fuchsia transition-colors duration-500 z-10"></div>
          <div class="absolute bottom-0 left-0 w-16 h-16 border-b-[3px] border-l-[3px] border-transparent group-hover:border-brand-fuchsia transition-colors duration-500 z-10"></div>
        </div>
      ))}
    </div>

  </div>
</section>
