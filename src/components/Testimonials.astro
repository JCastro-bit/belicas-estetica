---
// Testimonials.astro
const reviews = [
  { text: "Llegué queriendo un cambio y salí sintiéndome otra persona. Belica's es magia.", author: "Fernanda M." },
  { text: "Nadie me ha hecho un alisado tan perfecto. Ya no voy a ningún otro lugar.", author: "Daniela R." },
  { text: "El trato es increíble y los resultados siempre superan mis expectativas.", author: "Valentina C." }
];
---
<section class="bg-brand-dark py-24 md:py-32 relative">
  <!-- Subtle background glow -->
  <div class="absolute bottom-0 right-0 w-[50vw] h-[50vw] bg-magenta-600/5 rounded-full blur-[120px] -z-10 pointer-events-none"></div>

  <div class="container mx-auto px-4 lg:px-8">
    <div class="text-center mb-16 md:mb-24 flex flex-col items-center">
      <h2 class="font-display text-6xl md:text-8xl lg:text-[100px] leading-[0.8] tracking-tighter uppercase text-white mb-6">
        LA VERDAD <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-fuchsia to-magenta-600">NO SE OCULTA</span>
      </h2>
      <div class="w-24 h-1.5 bg-brand-fuchsia mt-6"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 w-full max-w-7xl mx-auto">
      {reviews.map((review, i) => (
        <div class="bg-[#0a0a0a] border border-white/5 hover:border-brand-fuchsia/40 p-10 md:p-12 relative group hover:-translate-y-3 transition-all duration-500 shadow-xl hover:shadow-[0_20px_40px_rgba(217,70,239,0.1)]">
          <!-- Quote Icon -->
          <div class="absolute -top-6 -left-3 text-brand-fuchsia/20 group-hover:text-brand-fuchsia/40 transition-colors duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
          </div>
          
          <div class="relative z-10 flex flex-col h-full justify-between">
            <div>
              <!-- Stars -->
              <div class="flex gap-1.5 mb-8 text-brand-fuchsia">
                {[...Array(5)].map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                ))}
              </div>
              
              <!-- Text -->
              <p class="font-body text-xl md:text-2xl text-gray-300 font-light leading-snug mb-10 italic">
                "{review.text}"
              </p>
            </div>
            
            <!-- Author -->
            <div class="flex items-center gap-5 mt-auto">
              <div class="w-14 h-14 bg-zinc-900 border border-white/10 flex items-center justify-center font-display text-3xl text-white/50 group-hover:text-white group-hover:bg-brand-fuchsia group-hover:border-brand-fuchsia transition-colors duration-300">
                {review.author.charAt(0)}
              </div>
              <div class="font-display text-2xl md:text-3xl text-white tracking-widest uppercase">
                {review.author}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
