---
// InstagramGrid.astro
const images = [
  "https://images.unsplash.com/photo-1595476108010-b4d1f10d5e43?q=80&w=600&h=600&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1522337660859-02fbefca4702?q=80&w=600&h=600&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1580618671404-187515e019f8?q=80&w=600&h=600&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1519699047748-de8e457a634e?q=80&w=600&h=600&auto=format&fit=crop"
];
---
<section class="bg-[#050505] py-20 border-t border-white/5 relative z-10">
  <div class="container mx-auto px-4 lg:px-8 text-center">
    <h2 class="font-display text-4xl md:text-6xl lg:text-[80px] leading-none uppercase text-white mb-4">
      SÍGUENOS EN <span class="text-brand-fuchsia">INSTAGRAM</span>
    </h2>
    <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" class="font-body text-gray-400 hover:text-brand-fuchsia transition-colors tracking-widest uppercase text-sm md:text-base mb-12 inline-block">
      @belicas.estetica
    </a>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 max-w-7xl mx-auto">
      {images.map((src, i) => (
        <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" class="group relative aspect-square overflow-hidden block border border-white/5 hover:border-brand-fuchsia/50 transition-colors duration-500">
          <img src={src} alt="Instagram post" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-700 grayscale group-hover:grayscale-0 opacity-80 group-hover:opacity-100" loading="lazy">
          <div class="absolute inset-0 bg-brand-fuchsia/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
