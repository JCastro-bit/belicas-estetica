---
// Contact.astro
---
<section class="bg-[#0a0a0a] border-t border-brand-fuchsia/20 relative overflow-hidden flex flex-col items-center">
  <!-- Top glow line -->
  <div class="w-full absolute top-0 left-0 h-[2px] bg-gradient-to-r from-transparent via-brand-fuchsia to-transparent opacity-70"></div>
  
  <div class="absolute bottom-0 left-0 w-[60vw] h-[60vw] bg-brand-fuchsia/5 rounded-full blur-[150px] -z-10 pointer-events-none"></div>

  <div class="container mx-auto px-4 lg:px-8 py-20 md:py-32 relative z-10 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 items-center w-full max-w-7xl mx-auto">
      
      <!-- Info Contacto -->
      <div class="flex flex-col gap-10">
        <div>
          <h2 class="font-display text-5xl md:text-7xl lg:text-[90px] leading-[0.8] tracking-tighter uppercase text-white mb-6">
            ESTAMOS <br />
            <span class="text-brand-fuchsia glow-fuchsia">ESPERÁNDOTE</span>
          </h2>
          <p class="font-body text-gray-400 text-lg uppercase tracking-widest font-light">
            Reserva con anticipación.
          </p>
        </div>

        <div class="space-y-8 md:space-y-10 border-l-2 border-white/5 pl-6 md:pl-8">
          <!-- Ubicación -->
          <div class="flex items-start gap-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-fuchsia mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <h4 class="font-display text-3xl text-white uppercase tracking-wider mb-2">Ubicación</h4>
              <p class="font-body text-gray-300 font-light text-lg">Guadalajara, Jalisco, México</p>
            </div>
          </div>

          <!-- Teléfono -->
          <div class="flex items-start gap-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-fuchsia mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div>
              <h4 class="font-display text-3xl text-white uppercase tracking-wider mb-2">Agenda</h4>
              <a href="https://wa.me/523333986710" target="_blank" class="font-body text-gray-300 hover:text-brand-fuchsia transition-colors font-light text-xl inline-block">+52 33 3398 6710</a>
            </div>
          </div>

          <!-- Horario -->
          <div class="flex items-start gap-5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-fuchsia mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <h4 class="font-display text-3xl text-white uppercase tracking-wider mb-2">Horario</h4>
              <p class="font-body text-gray-300 font-light text-lg mb-1">Lunes a Viernes: 10:00 am - 8:00 pm</p>
              <p class="font-body text-gray-300 font-light text-lg">Sábados: 9:00 am - 4:00 pm</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Mapa (Placeholder) -->
      <div class="w-full aspect-square bg-[#111111] border border-white/10 relative group overflow-hidden opacity-90 hover:opacity-100 transition-opacity duration-500 shadow-2xl">
        <div class="absolute inset-0 bg-brand-dark/70 backdrop-blur-sm z-10 flex flex-col items-center justify-center p-6 text-center group-hover:bg-brand-dark/50 transition-colors duration-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-brand-fuchsia mb-4 group-hover:scale-110 transition-transform duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          <span class="font-display text-2xl text-white tracking-widest uppercase">Ver en Google Maps</span>
          <span class="text-sm text-gray-400 mt-2 font-body font-light">Guadalajara, Jalisco</span>
        </div>
        <!-- Abstract gradient map background -->
        <div class="absolute inset-0 opacity-30 bg-[url('https://images.unsplash.com/photo-1524661135-423995f22d0b?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center grayscale group-hover:scale-105 transition-transform duration-[2s]"></div>
        <div class="absolute inset-0 bg-gradient-to-tr from-brand-fuchsia/50 to-transparent mix-blend-overlay"></div>
      </div>

    </div>
  </div>

  <footer class="w-full border-t border-white/5 py-10 text-center bg-[#050505]">
    <div class="container mx-auto px-4 flex flex-col items-center">
      <div class="font-display text-2xl md:text-3xl text-white/20 mb-4 tracking-[0.2em]">BELICA'S</div>
      <p class="font-body text-gray-500 text-xs md:text-sm tracking-widest uppercase mb-1">
        &copy; {new Date().getFullYear()} Belica's Estética. Todos los derechos reservados.
      </p>
    </div>
  </footer>
</section>
